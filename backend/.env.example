# Local-only example; copy to .env (gitignored) and fill in.
# In production, NEVER set IPLODDS_GITHUB_MODELS_TOKEN here — it comes from Key Vault.

IPLODDS_ENV=dev
IPLODDS_LOG_LEVEL=INFO
IPLODDS_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# LLM (free tier, get a token at https://github.com/settings/tokens — fine-grained, no scopes needed for Models)
IPLODDS_LLM_PROVIDER=github
IPLODDS_GITHUB_MODELS_TOKEN=ghp_replace_me
IPLODDS_GITHUB_MODELS_MODEL=gpt-4o-mini

# Cache: leave blank to use in-memory cache locally
IPLODDS_BLOB_ACCOUNT_URL=

# Feature flags
IPLODDS_FEATURE_PRIORS=true
IPLODDS_FEATURE_AGENT=true
IPLODDS_FEATURE_LEVERAGE=true
IPLODDS_FEATURE_SCOUT=false
